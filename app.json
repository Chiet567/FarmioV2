{
  "expo": {
    "name": "FermeConnect",
    "slug": "fermeconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fermeconnect",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fermeconnect.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fermeconnect.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#16a34a",
          "dark": {
            "backgroundColor": "#15803d"
          }
        }
      ],
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "https://weaycioahsuhucskpozg .supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1 NilsInR5cC I6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFz ZSIsInJIZil6IndlYXljaW9haHN1aHVjc2t wb3pnliwicm9sZSI6ImFub24iLCJpYXQ iOjE3NzQ1NTI3NzIsImV4cCI6MjA5MD EyODc3Mn0.LcRNXq4Ou-Lfl41C53Cuv EDzL6L17PROsUpBkltSMos"
    }
  }
}
